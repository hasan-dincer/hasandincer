---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getUrl } from '../../utils/url';

// Fetch books and chapters
const kitaplar = (await getCollection('kitaplar'))
  .filter((k) => !k.data.draft)
  .sort((a, b) => a.data.sira - b.data.sira);

const tumBolumler = (await getCollection('bolumler'))
  .filter((b) => !b.data.draft)
  .sort((a, b) => a.data.bolumNo - b.data.bolumNo);

// Group chapters by book slug
const bolumlerByKitap = new Map<string, typeof tumBolumler>();
for (const bolum of tumBolumler) {
  const slug = bolum.data.kitapSlug;
  if (!bolumlerByKitap.has(slug)) bolumlerByKitap.set(slug, []);
  bolumlerByKitap.get(slug)!.push(bolum);
}
---

<BaseLayout title="Kitaplar" description="Hasan Dinçer'in tüm kitapları — kapak, özet ve örnek bölümler.">
  <section class="page-container">
    <h1 class="section-title">Kitaplar</h1>

    <div class="book-list">
      {kitaplar.map((kitap) => {
        const bolumler = bolumlerByKitap.get(kitap.slug) ?? [];
        return (
          <article class="book-card" id={`kitap-${kitap.slug}`}>
            {/* Cover image */}
            <a href={getUrl(`kitaplar/${kitap.slug}`)} class="book-cover-link">
              {kitap.data.kapakGorsel ? (
                <img
                  src={getUrl(kitap.data.kapakGorsel)}
                  alt={`${kitap.data.baslik} kapak görseli`}
                  class="book-cover"
                  loading="lazy"
                />
              ) : (
                <div class="book-cover book-cover--placeholder">
                  <span class="placeholder-initial">{kitap.data.baslik.charAt(0)}</span>
                </div>
              )}
            </a>

            {/* Book details */}
            <div class="book-details">
              <div class="book-header">
                <span class="book-genre">{kitap.data.tur}</span>
                <h2 class="book-title">
                  <a href={getUrl(`kitaplar/${kitap.slug}`)}>{kitap.data.baslik}</a>
                </h2>
                <div class="book-meta">
                  {kitap.data.yayinevi && <span>{kitap.data.yayinevi}</span>}
                  {kitap.data.yayinTarihi && (
                    <span class="book-meta-sep">{kitap.data.yayinTarihi.getFullYear()}</span>
                  )}
                </div>
              </div>

              {kitap.data.ozet && (
                <p class="book-description">{kitap.data.ozet}</p>
              )}

              {/* Sample chapter links */}
              {bolumler.length > 0 && (
                <div class="book-samples">
                  <h4 class="book-samples-label">Kitaptan Kesitler</h4>
                  <ul class="book-samples-list">
                    {bolumler.map((bolum) => (
                      <li>
                        <a
                          href={getUrl(`kitaplar/${kitap.slug}/${bolum.slug.split('/').pop()}`)}
                          class="sample-link"
                          id={`sample-${kitap.slug}-${bolum.data.bolumNo}`}
                        >
                          <span class="sample-number">{String(bolum.data.bolumNo).padStart(2, '0')}</span>
                          <span class="sample-title">{bolum.data.baslik}</span>
                          <span class="sample-arrow">→</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <a href={getUrl(`kitaplar/${kitap.slug}`)} class="book-detail-link">
                Kitap Detayı →
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Book List ── */
  .book-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3xl) var(--space-2xl);
  }

  /* ── Book Card (vertical layout) ── */
  .book-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: stretch;
    max-width: 24rem;
    margin: 0 auto;
  }

  /* ── Cover ── */
  .book-cover-link {
    display: block;
    width: 100%;
    max-width: 20rem;
    margin: 0 auto;
    text-decoration: none;
    border-radius: 4px;
    overflow: hidden;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.08),
      0 1px 4px rgba(0, 0, 0, 0.04);
    transition: transform var(--transition), box-shadow var(--transition);
    aspect-ratio: 2 / 3;
  }

  .book-cover-link:hover {
    transform: translateY(-4px) rotate(-1deg);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.12),
      0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-cover--placeholder {
    background: linear-gradient(145deg, var(--color-accent), var(--color-accent-light));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-initial {
    font-family: var(--font-serif);
    font-size: 4rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    font-style: italic;
  }

  /* ── Details ── */
  .book-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-sm);
  }

  .book-genre {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    display: inline-block;
    margin-bottom: var(--space-xs);
  }

  .book-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: var(--space-xs);
  }

  .book-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition);
  }

  .book-title a:hover {
    color: var(--color-accent);
  }

  .book-meta {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-sm);
  }

  .book-meta-sep::before {
    content: '·';
    margin-right: var(--space-sm);
  }

  .book-description {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 0;
  }

  /* ── Sample chapter links ── */
  .book-samples {
    margin-top: var(--space-sm);
  }

  .book-samples-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .book-samples-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--color-border-light);
    border-radius: 6px;
    overflow: hidden;
  }

  .sample-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0.7rem var(--space-lg);
    text-decoration: none;
    color: var(--color-text);
    background: var(--color-surface);
    transition: background var(--transition), color var(--transition);
    font-size: 0.92rem;
  }

  .sample-link:hover {
    background: var(--color-bg-alt);
    color: var(--color-accent);
  }

  .sample-number {
    font-family: var(--font-serif);
    font-weight: 600;
    color: var(--color-accent);
    min-width: 1.8rem;
    font-size: 0.95rem;
  }

  .sample-title {
    flex: 1;
    font-family: var(--font-serif);
    font-weight: 500;
  }

  .sample-arrow {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition), transform var(--transition);
  }

  .sample-link:hover .sample-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Detail link ── */
  .book-detail-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-sm);
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }

  .book-detail-link:hover {
    border-bottom-color: var(--color-accent);
    color: var(--color-text);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .book-list {
      grid-template-columns: 1fr;
    }

    .book-cover-link {
      max-width: 20rem;
      margin: 0 auto;
    }

    .book-card {
      align-items: center;
      text-align: center;
    }

    .book-meta {
      justify-content: center;
    }
  }
</style>
