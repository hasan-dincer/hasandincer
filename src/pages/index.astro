---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const kitaplar = (await getCollection('kitaplar'))
  .filter((k) => !k.data.draft)
  .sort((a, b) => a.data.sira - b.data.sira);
---

<BaseLayout title="Ana Sayfa" description="Hasan Dinçer — Yazar, roman ve edebiyat dünyası.">
  <div class="hero-container">
    <h1 class="author-title home-title">Hasan Dinçer</h1>
    <!-- Bu resmin yolunu (src) dilediğiniz gibi değiştirebilirsiniz -->
    <img src={getUrl('images/hasan_dincer_bio.jpeg')} alt="Hasan Dinçer" class="hero-side-image" />
  </div>
  <div class="home-image-container">
    <img src={getUrl('images/iki_kitap_arka_fon.png')} alt="Hasan Dinçer" class="home-image" />
  </div>
  

  <section class="page-container">
    
    <div class="card-grid">
      {kitaplar.map((kitap) => (
        <a href={getUrl(`kitaplar/${kitap.slug}`)} class="card" id={`kitap-${kitap.slug}`}>
          <span class="card-meta">{kitap.data.tur}</span>
          <h3 class="card-title">{kitap.data.baslik}</h3>
          {kitap.data.ozet && (
                <p class="card-summary" set:html={kitap.data.ozet}></p>
              )}
          <div class="card-footer">
            {kitap.data.yayinevi && <span>{kitap.data.yayinevi}</span>}
            {kitap.data.yayinTarihi && (
              <span>{kitap.data.yayinTarihi.getFullYear()}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>

  .hero-container {
    position: relative;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .home-title {
    transform: translateX(-6rem);
  }

  .hero-side-image {
    position: absolute;
    right: 5%;
    top: 0.5rem; /* Başlıkla aynı hizalarda başlaması için */
    width: 120px; /* Genişliği buradan ayarlayabilirsiniz */
    height: auto;
    margin-right: -1rem;
    opacity: 0.9; /* Saydamlık (0 ile 1 arası, 1=tam görünür, 0=tam saydam) */
    z-index: 10; /* Alttaki resmin üstüne çıkması için */
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  @media (max-width: 768px) {
    .hero-side-image {
      /* Mobilde ekran küçük olduğu için resmi küçültebilir veya gizleyebiliriz. Şu an küçülttüm: */
      width: 120px;
      right: 5%;
      top: 1rem;
    }
  }

  .home-image-container {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: 2rem;
    pointer-events: none;
  }

  .home-image {
    width: 65%;
    height: auto;
    opacity: 1;
  }

  /* Koyu temada görselin fazla parlamaması için ekstra karartma */
  :global(.dark) .home-image {
    opacity: 1;
  }
</style>
