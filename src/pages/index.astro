---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const kitaplar = (await getCollection('kitaplar'))
  .filter((k) => !k.data.draft)
  .sort((a, b) => a.data.sira - b.data.sira);
---

<BaseLayout title="Ana Sayfa" description="Hasan Dinçer — Yazar, roman ve edebiyat dünyası.">
  <div class="home-background" style={`background-image: url('${getUrl('images/iki_kitap_seffaf.png')}');`}></div>
  <section class="hero">
    <h1>Hasan Dinçer</h1>
    <hr class="hero-divider" />
    <p class="hero-subtitle">
      Kelimelerin sessiz akışında, hikâyelerin izinde.
      <br />
      Roman, öykü ve edebiyat üzerine yazılar.
    </p>
  </section>

  <section class="page-container">
    <h2 class="section-title">Kitaplar</h2>
    <div class="card-grid">
      {kitaplar.map((kitap) => (
        <a href={getUrl(`kitaplar/${kitap.slug}`)} class="card" id={`kitap-${kitap.slug}`}>
          <span class="card-meta">{kitap.data.tur}</span>
          <h3 class="card-title">{kitap.data.baslik}</h3>
          {kitap.data.ozet && <p class="card-summary">{kitap.data.ozet}</p>}
          <div class="card-footer">
            {kitap.data.yayinevi && <span>{kitap.data.yayinevi}</span>}
            {kitap.data.yayinTarihi && (
              <span>{kitap.data.yayinTarihi.getFullYear()}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .home-background {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
    height: 100vh;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -1;
    pointer-events: none;
    opacity: 0.2;
  }

  /* Koyu temada görselin fazla parlamaması için ekstra karartma */
  :global(.dark) .home-background {
    opacity: 0.1;
  }
</style>
