---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getUrl } from '../utils/url';

const kitaplar = (await getCollection('kitaplar'))
  .filter((k) => !k.data.draft)
  .sort((a, b) => a.data.sira - b.data.sira);
---

<BaseLayout title="Ana Sayfa" description="Hasan Dinçer — Yazar, roman ve edebiyat dünyası.">
  <h1 style="text-align: center; margin-top: 2rem;">Hasan Dinçer</h1>
  <div class="home-background" style={`background-image: url('${getUrl('images/iki_kitap_arka_fon.png')}');`}></div>
  <section class="hero">
    
    <hr class="hero-divider" />
    <p class="hero-subtitle">
      
    </p>
  </section>

  <section class="page-container">
    <h2 class="section-title" style="color: #ffffff; text-shadow: 0 2px 4px rgba(0,0,0,0.8); border-bottom-color: rgba(255,255,255,0.3); text-align: center; max-width: fit-content; margin-left: auto; margin-right: auto;">Kitaplar</h2>
    <div class="card-grid">
      {kitaplar.map((kitap) => (
        <a href={getUrl(`kitaplar/${kitap.slug}`)} class="card" id={`kitap-${kitap.slug}`}>
          <span class="card-meta">{kitap.data.tur}</span>
          <h3 class="card-title">{kitap.data.baslik}</h3>
          {kitap.data.ozet && <p class="card-summary">{kitap.data.ozet}</p>}
          <div class="card-footer">
            {kitap.data.yayinevi && <span>{kitap.data.yayinevi}</span>}
            {kitap.data.yayinTarihi && (
              <span>{kitap.data.yayinTarihi.getFullYear()}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .home-background {
    position: fixed;
    top: 160px;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: calc(100vh - 160px);
    background-size: contain;
    background-position: center top;
    background-repeat: no-repeat;
    z-index: -1;
    pointer-events: none;
    opacity: 0.8;
  }

  /* Koyu temada görselin fazla parlamaması için ekstra karartma */
  :global(.dark) .home-background {
    opacity: 0.1;
  }
</style>
